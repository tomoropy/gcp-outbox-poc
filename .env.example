GCP_PROJECT_ID=demo-gcp-project
SPANNER_INSTANCE_ID=gcp-outbox-poc
SPANNER_DATABASE_ID=gcp-outbox-poc
PORT=8080

# Worker
WORKER_ID=local-worker-1
WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL=1s
OUTBOX_LEASE_SECONDS=60
OUTBOX_BACKOFF_BASE=2s
OUTBOX_BACKOFF_MAX=1024s
WORKER_HTTP_TIMEOUT=20s
WORKER_PROCESS_DELAY=0s

# Simulator fault injection
SIMULATOR_FORCE_STATUS=
SIMULATOR_FAIL_FIRST_N=0
SIMULATOR_DELAY=0s

# Jobs
EXPIRE_BILLING_LOOKBACK=24h
OUTBOX_CLEANUP_RETENTION=720h

# Outbox autoscaler job
AUTOSCALER_REGION=asia-northeast1
AUTOSCALER_WORKER_POOL=gcp-outbox-poc-worker
AUTOSCALER_MIN_WORKERS=1
AUTOSCALER_MAX_WORKERS=5
AUTOSCALER_SCALE_UP_BACKLOG=100
AUTOSCALER_SCALE_UP_WORKERS=3
AUTOSCALER_MAX_BACKLOG=500
AUTOSCALER_OLDEST_BACKLOG_AGE=5m
AUTOSCALER_DRY_RUN=false
